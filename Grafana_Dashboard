          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH targets AS (\r\n  SELECT itemid, name\r\n  FROM prediction_targets\r\n  WHERE host = '$host'\r\n    AND name = '$disk'\r\n    AND enabled = true\r\n),\r\nlatest_runs AS (\r\n  SELECT \r\n    f.itemid,\r\n    MAX(f.forecast_run_at) AS run_at\r\n  FROM forecasts f\r\n  JOIN targets t ON f.itemid = t.itemid\r\n  GROUP BY f.itemid\r\n)\r\nSELECT\r\n  t.name AS \"Маунтпоинт\",\r\n  ROUND(AVG(CASE WHEN f.ds >= NOW() + INTERVAL '30 days' THEN f.yhat END)::NUMERIC, 2) AS \"30d (TB)\",\r\n  ROUND(AVG(CASE WHEN f.ds >= NOW() + INTERVAL '60 days' THEN f.yhat END)::NUMERIC, 2) AS \"60d (TB)\",\r\n  ROUND(AVG(CASE WHEN f.ds >= NOW() + INTERVAL '88 days' THEN f.yhat END)::NUMERIC, 2) AS \"90d (TB)\"\r\nFROM forecasts f\r\nJOIN targets t ON f.itemid = t.itemid\r\nJOIN latest_runs l ON f.itemid = l.itemid AND f.forecast_run_at = l.run_at\r\nGROUP BY t.name\r\nORDER BY t.name;",
          "refId": "A",
