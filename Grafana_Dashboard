          "rawSql": "WITH target AS (\r\n  SELECT itemid\r\n  FROM prediction_targets\r\n  WHERE host = '$host'\r\n    AND name = '$disk'\r\n    AND enabled = true\r\n),\r\nlatest_run AS (\r\n  SELECT MAX(run_id) AS run_id  -- ← используем run_id!\r\n  FROM forecasts f\r\n  JOIN target t ON f.itemid = t.itemid\r\n)\r\nSELECT\r\n  f.ds AS \"time\",\r\n  f.yhat AS \"forecast\",\r\n  f.yhat_lower AS \"lower\",\r\n  f.yhat_upper AS \"upper\"\r\nFROM forecasts f\r\nJOIN target t ON f.itemid = t.itemid\r\nJOIN latest_run l ON f.run_id = l.run_id  -- ← join по run_id\r\nORDER BY f.ds;",
